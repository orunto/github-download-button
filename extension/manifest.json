{
  "manifest_version": 3,
  "name": "GitHub Download Button",
  "version": "1.0.0",
  "description": "Instant, OS-filtered download options for any GitHub repo.",
  "permissions": ["storage", "activeTab", "tabs"],
  "host_permissions": [
    "https://github.com/*",
    "http://localhost:3000/*",
    "https://githubdownloadbutton.orunto.dev/*"
  ],
  "content_scripts": [
    {
      "matches": ["https://github.com/*/*"],
      "js": ["utils.js", "content.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "web_accessible_resources": [
    {
      "resources": ["icons/icon16.png", "icons/icon32.png", "icons/icon48.png", "icons/icon128.png"],
      "matches": ["https://github.com/*"]
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "GitHub Download Button",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  }
}
